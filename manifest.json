{
  "id": "food-journal-nasarudheenn",
  "name": "Food Journal",
  "short_name": "Food Journal",
  "description": "Personal food diary with nutrition tracking, recipes and reports",
  "start_url": "/food-journal/index.html",
  "scope": "/food-journal/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "background_color": "#0f0e0c",
  "theme_color": "#0f0e0c",
  "lang": "en",
  "dir": "ltr",
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://nasarudheenn.github.io/food-journal/manifest.json"
    }
  ],
  "categories": ["health", "lifestyle"],
  "screenshots": [
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Food Journal Diary"
    }
  ],
  "icons": [
    {"src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any"},
    {"src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable"},
    {"src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any"},
    {"src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable"}
  ],
  "shortcuts": [
    {
      "name": "Log Food",
      "short_name": "Log Food",
      "description": "Quickly log food to your diary",
      "url": "/food-journal/index.html",
      "icons": [{"src": "icon-192.png", "sizes": "192x192", "type": "image/png"}]
    },
    {
      "name": "Recipe Book",
      "short_name": "Recipes",
      "description": "Browse your saved recipes",
      "url": "/food-journal/index.html",
      "icons": [{"src": "icon-192.png", "sizes": "192x192", "type": "image/png"}]
    }
  ],
  "share_target": {
    "action": "/food-journal/index.html",
    "method": "GET",
    "params": {"title": "title", "text": "text", "url": "url"}
  },
  "launch_handler": {"client_mode": "focus-existing"},
  "handle_links": "preferred",
  "edge_side_panel": {"preferred_width": 480},
  "note_taking": {"new_note_url": "/food-journal/index.html"},
  "file_handlers": [
    {
      "action": "/food-journal/index.html",
      "accept": {"application/json": [".json"]}
    }
  ],
  "protocol_handlers": [
    {"protocol": "web+foodjournal", "url": "/food-journal/index.html?uri=%s"}
  ],
  "scope_extensions": [
    {
      "origin": "https://nasarudheenn.github.io",
      "origin_as_wildcard": false
    }
  ],
  "widgets": [
    {
      "name": "Food Journal",
      "short_name": "Food Journal",
      "description": "Track your daily nutrition",
      "tag": "food-journal-widget",
      "template": "generic-template",
      "ms_ac_template": "/food-journal/widget-template.json",
      "data": "/food-journal/index.html",
      "type": "application/json",
      "screenshots": [
        {
          "src": "icon-512.png",
          "sizes": "512x512",
          "type": "image/png",
          "label": "Food Journal Widget"
        }
      ],
      "icons": [
        {
          "src": "icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ]
}
